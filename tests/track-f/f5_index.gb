# Track F / F5 target
# Expected: reads stdin, splits on newlines, binds the second line (index 1),
# and prints it.
# Status: currently passes via general lowering.
# Out-of-range index behavior: trap with diagnostic (policy defined in F5).
main : Unit -> Unit can Print, Read
main =
  text = Read.read ()
  lines = string.split text "\n"
  line = list.get lines 1
  Print.println line
