# comment.line — everything after `#` on this line

# string.quoted.double — with escape sequences
"hello\nworld\t!\""

# constant.numeric
42

# constant.language
True
False

# keyword.control
if True
  "yes"
else
  "no"

case 1
  1 -> "one"
  _ -> "other"

# keyword.other
type MyType = MyType(field: String)
effect MyEffect
  op: String -> Unit
import goby/string as str
mut count = 0
@embed MyEffect __goby_embeded_effect_stdout_handler
fn_lambda = fn x y -> x + y

# with / in / resume / can (keyword.control)
foo : String -> Unit can MyEffect
foo s =
  with
    op msg ->
      resume msg
  in
    op s

bar : String -> Unit can MyEffect
bar s =
  h = handler
    op msg ->
      resume msg
  with h in
    op s

# storage.type (built-in)
baz : Int -> String -> Bool -> Unit -> List Int -> Unit
baz n s b u xs = print "ok"

# entity.name.type (UpperCamelCase, user-defined)
# MyType, MyEffect are highlighted as entity.name.type

# keyword.operator
result = 1 + 2 * 3
compare_check = 1 <= 2 && 3 >= 1
eq_check = result == 9
bool_check = !False || True
math_check = 5 - 1 / 2 % 2
pipe_result = [1, 2, 3] |> print
lambda_fn = fn x -> x + 1

# punctuation
pair = (1, "two")
lst = [1, 2, 3]
rec = MyType(field: "value")
