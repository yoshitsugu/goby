import goby/iterator ( Iterator, GraphemeState )

grapheme_count : String -> Int
grapheme_count value =
  mut n = 0
  with
    yield _ _ ->
      resume (True, ())
  in
    n := __goby_string_each_grapheme value
  n

split_with_empty_delimiter : String -> List String
split_with_empty_delimiter value =
  initial =
    GraphemeState(grapheme: "", parts: [], current: "", delimiter: "", seen: False)
  mut final = initial
  with
    yield grapheme step ->
      next_parts = __goby_list_push_string step.parts grapheme
      resume (True, GraphemeState(
        grapheme: "",
        parts: next_parts,
        current: "",
        delimiter: "",
        seen: True
      ))
  in
    final := __goby_string_each_grapheme value initial
  if final.seen
    final.parts
  else
    []

split_with_single_delimiter : String -> String -> List String
split_with_single_delimiter value sep =
  initial = GraphemeState(grapheme: "", parts: [], current: "", delimiter: sep, seen: False)
  mut final = initial
  with
    yield grapheme step ->
      if grapheme == step.delimiter
        next_parts = __goby_list_push_string step.parts step.current
        resume (True, GraphemeState(
          grapheme: "",
          parts: next_parts,
          current: "",
          delimiter: step.delimiter,
          seen: True
        ))
      else
        next_current = "${step.current}${grapheme}"
        resume (True, GraphemeState(
          grapheme: "",
          parts: step.parts,
          current: next_current,
          delimiter: step.delimiter,
          seen: True
        ))
  in
    final := __goby_string_each_grapheme value initial
  if final.seen
    __goby_list_push_string final.parts final.current
  else
    []

prefix_matches : List String -> List String -> Bool
prefix_matches xs prefix =
  case prefix
    [] -> True
    [part, ..rest_prefix] ->
      case xs
        [] -> False
        [x, ..rest_xs] ->
          if x == part
            prefix_matches rest_xs rest_prefix
          else
            False

drop_matched_prefix : List String -> List String -> List String
drop_matched_prefix xs prefix =
  case prefix
    [] -> xs
    [_, ..rest_prefix] ->
      case xs
        [] -> []
        [_, ..rest_xs] ->
          drop_matched_prefix rest_xs rest_prefix

split_multi_parts : List String -> List String -> String -> List String -> List String
split_multi_parts xs sep_parts current parts =
  case xs
    [] -> __goby_list_push_string parts current
    _ ->
      pm = prefix_matches xs sep_parts
      if pm
        next_parts = __goby_list_push_string parts current
        rest = drop_matched_prefix xs sep_parts
        split_multi_parts rest sep_parts "" next_parts
      else
        case xs
          [] -> __goby_list_push_string parts current
          [x, ..rest_xs] ->
            next_current = "${current}${x}"
            split_multi_parts rest_xs sep_parts next_current parts

split_with_multi_delimiter : String -> String -> List String
split_with_multi_delimiter value sep =
  gs_value = graphemes value
  gs_sep = graphemes sep
  split_multi_parts gs_value gs_sep "" []

split : String -> String -> List String
split value sep =
  if value == ""
    []
  else
    if sep == ""
      split_with_empty_delimiter value
    else
      gc = grapheme_count sep
      if gc == 1
        split_with_single_delimiter value sep
      else
        split_with_multi_delimiter value sep

graphemes : String -> List String
graphemes value =
  initial =
    GraphemeState(grapheme: "", parts: [], current: "", delimiter: "", seen: False)
  mut final = initial
  with
    yield grapheme step ->
      next_parts = __goby_list_push_string step.parts grapheme
      resume (True, GraphemeState(
        grapheme: "",
        parts: next_parts,
        current: "",
        delimiter: "",
        seen: True
      ))
  in
    final := __goby_string_each_grapheme value initial
  if final.seen
    final.parts
  else
    []

length : String -> Int
length value = __goby_string_length value
