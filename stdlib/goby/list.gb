join : List String -> String -> String
join values sep =
  case values
    [] -> ""
    [x] -> x
    [x, ..xxs] -> "${x}${sep}${join xxs sep}"

each : List a -> (a -> Unit) -> Unit
each xs f =
  case xs
    [] -> ()
    [x, ..xxs] ->
      f x
      each xxs f

map : List a -> (a -> b) -> List b
map xs f =
  case xs
    [] -> []
    [x, ..xxs] -> [f x, ..map xxs f]

length : List a -> Int
length xs =
  case xs
    [] -> 0
    [x, ..xxs] -> 1 + length xxs

# Left fold. The callback receives the accumulator first: f acc elem.
fold : List a -> b -> (b -> a -> b) -> b
fold xs acc f =
  case xs
    [] -> acc
    [x, ..xxs] -> fold xxs (f acc x) f
