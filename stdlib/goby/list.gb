join : List String -> String -> String
join values sep = list.join(values, sep)

import goby/iterator

iter : List a -> b -> b can Iterator
iter xs state =
  case xs
    [] -> state
    [x, ..xxs] ->
      decision = yield x state
      if decision.0
        iter xxs decision.1
      else
        decision.1

each : List a -> (a -> Unit) -> Unit
each xs f =
  emit_handler = handler
    yield x _ ->
      f x
      resume (True, ())
  with emit_handler
  in
    iter xs ()

map : List a -> (a -> b) -> List b
map xs f =
  emit_handler = handler
    yield x ys ->
      ys 
      resume (True, [f(x), ..ys])
  with emit_handler
  in
    iter xs []
