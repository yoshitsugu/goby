import goby/prelude

# Int
add : Int -> Int -> Int
add a b = a + b

add_ten_and_two : Unit -> Int
add_ten_and_two =
  a = 10
  b = 2
  a + b

# String (UTF-8 only)
concatenate : String -> String -> String
# String interpolation is available via ${}
concatenate a b = "${a}${b}"

print_string : Unit -> Unit can Print
print_string =
  a = "Hello"
  println a

# Tuple
a : (String, Int)
a = ("Hello", 3)

main =
  t = add(1, 2)
  hello = concatenate("Hello ", "Goby")
  println "${t}${hello}"

  # Tuple members are accessed by index: .0, .1, ...
  println a.0
  println a.1
