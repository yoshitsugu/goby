effect Iterator a b
  yield : a -> b -> (Bool, b)

yield_int_state : String -> Int -> (Bool, Int) can Iterator
yield_int_state value state = yield value state

count_values : Unit -> Int can Iterator
count_values =
  s1 = yield_int_state "a" 0
  s2 = if s1.0
    yield_int_state "b" s1.1
  else
    s1
  s3 = if s2.0
    yield_int_state "c" s2.1
  else
    s2
  s3.1

main : Unit -> Unit
main =
  # state-less mode: Unit state
  with_handler
    yield value _ ->
      print "tick:${value}"
      resume (True, ())
  in
    yield "a" ()
    yield "b" ()
    yield "c" ()

  # state-threaded mode: Int state
  count_all = with_handler
    yield _ step ->
      resume (True, step + 1)
  in
    count_values ()
  print "${count_all}"

  # early-stop mode: return (False, state)
  count_early_stop = with_handler
    yield value step ->
      if value == "b"
        resume (False, step)
      else
        resume (True, step + 1)
  in
    count_values ()
  print "${count_early_stop}"
