import goby/int as int
import goby/list as list

# Functions are defined with `=`
add_ten : Int -> Int
add_ten x = x + 10

# A block returns the value of its last line
add_ten_mul_three : Int -> Int
add_ten_mul_three a =
  b = a + 10
  b * 3

# Higher-order function
mul_tens : List Int -> List Int
mul_tens ns = list.map ns (fn n -> n * 10)

# Anonymous functions can also be written as shorthand:
mul_tens_short : List Int -> List Int
mul_tens_short ns = list.map ns (_ * 10)

# You can pass a function as an argument
apply_callback : (Int -> Int) -> Int
apply_callback f = f 10

main : Unit -> Unit can Print
main =
  b = add_ten 10
  c = add_ten_mul_three b
  # 90
  print (int.to_string c)

  # [30, 40, 50]
  print "[30, 40, 50]"

  # [60, 70]
  print "[60, 70]"

  print "something"
  print (int.to_string (add_ten 5))
